---
import CartFlow from '../components/cart/CartFlow';
import UserQRModal from '../components/UserQRModal';
import NavBar from '../components/NavBar.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  requiresAuth?: boolean;
  customerOnly?: boolean;
}

const { title, requiresAuth = false, customerOnly = false } = Astro.props;
---

<!doctype html>
<html lang="es-SV">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Pacifico&family=Poppins:wght@700;800;900&display=swap" rel="stylesheet" />
	</head>
	<body class="flex min-h-dvh flex-col bg-white text-slate-900">
		{requiresAuth && (
			customerOnly ? (
				<script is:inline>
					if (typeof window !== 'undefined') {
						const rawSession = window.localStorage.getItem('aloha_session');

						if (!rawSession) {
							window.location.replace('/');
						} else {
							try {
								const session = JSON.parse(rawSession);

								if (session.role === 'admin') {
									window.location.replace('/admin');
								}
							} catch {
								window.location.replace('/');
							}
						}
					}
				</script>
			) : (
				<script is:inline>
					if (typeof window !== 'undefined') {
						const rawSession = window.localStorage.getItem('aloha_session');

						if (!rawSession) {
							window.location.replace('/');
						}
					}
				</script>
			)
		)}

		<NavBar />
		<main
			id="page-main"
			class="w-full flex-1 bg-[radial-gradient(circle_at_top,_rgba(78,197,212,0.12),_transparent_28%),linear-gradient(180deg,_#ffffff_0%,_#FFF6E8_45%,_#f8fafc_100%)]"
			style="opacity:0"
		>
			<slot />
		</main>
		<footer class="bg-[#231F20] text-white">
			<!-- Compact footer row (desktop only) -->
			<div class="mx-auto hidden items-start gap-10 px-6 py-5 md:flex md:max-w-6xl">

				<!-- Logo + socials stacked -->
				<div class="flex shrink-0 flex-col items-center gap-2.5">
					<img src="/logo.png" alt="Aloha Loyalty" class="h-16 w-auto object-contain" />
					<div class="flex items-center gap-3.5">
						<a href="https://www.instagram.com/alohabowls.sv/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-white/40 transition-colors duration-200 hover:text-[#FF2F92]">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
								<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
								<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
							</svg>
						</a>
						<a href="https://www.tiktok.com/@alohabowls.sv" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="text-white/40 transition-colors duration-200 hover:text-[#FF2F92]">
							<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
								<path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
							</svg>
						</a>
						<a href="https://www.facebook.com/alohabowls.sv" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-white/40 transition-colors duration-200 hover:text-[#FF2F92]">
							<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
								<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
							</svg>
						</a>
					</div>
				</div>

				<div class="mt-1 w-px self-stretch bg-white/8"></div>

				<!-- Locaciones -->
				<div>
					<h3 class="mb-2 text-[10px] font-bold uppercase tracking-[0.25em] text-white/40">Locaciones</h3>
					<div class="flex flex-col gap-3 text-sm">
						<div>
							<p class="font-semibold text-white">CC. Hillside</p>
							<p class="text-xs text-white/50">Calle La Mascota, San Salvador</p>
							<p class="mt-0.5 text-xs text-white/35">Lun–Vie 9:30–6:00 · Sáb 9:30–2:00 · Dom Cerrado</p>
						</div>
						<div>
							<p class="font-semibold text-white">Multiplaza</p>
							<p class="text-xs text-white/50">Antiguo Cuscatlán, La Libertad</p>
							<p class="mt-0.5 text-xs text-white/35">Lun–Sáb 11:00–8:00 · Dom 11:00–4:00</p>
						</div>
					</div>
				</div>

				<!-- Navegación -->
				<div>
					<h3 class="mb-2 text-[10px] font-bold uppercase tracking-[0.25em] text-white/40">Navegación</h3>
					<ul class="space-y-1 text-sm">
						<li><a href="/" class="text-white/60 transition hover:text-white">Inicio</a></li>
						<li><a href="/menu" class="text-white/60 transition hover:text-white">Menú</a></li>
						<li><a href="/tiendas" class="text-white/60 transition hover:text-white">Locaciones</a></li>
						<li><a href="/retos" class="text-white/60 transition hover:text-white">Retos</a></li>
						<li><a id="footer-account-item" href="/dashboard" class="text-white/60 transition hover:text-white">Mi Cuenta</a></li>
					</ul>
				</div>

				<!-- Legal -->
				<div>
					<h3 class="mb-2 text-[10px] font-bold uppercase tracking-[0.25em] text-white/40">Legal</h3>
					<ul class="space-y-1 text-xs">
						<li><span class="cursor-not-allowed text-white/30">Términos</span></li>
						<li><span class="cursor-not-allowed text-white/30">Privacidad</span></li>
						<li><span class="cursor-not-allowed text-white/30">Cookies</span></li>
					</ul>
				</div>

			</div>
			<div class="px-6 py-3 text-center text-[11px] text-white/25 md:border-t md:border-white/10">
				© 2026 Aloha Loyalty. El Salvador. Todos los derechos reservados.
			</div>
		</footer>
		<CartFlow client:load />
		<UserQRModal client:load />

		<script>
			function animateIn() {
				const pageMain = document.getElementById('page-main');

				if (!pageMain) {
					return;
				}

				pageMain.animate(
					[
						{ opacity: 0, transform: 'translateY(16px)' },
						{ opacity: 1, transform: 'translateY(0)' }
					],
					{
						duration: 400,
						easing: 'cubic-bezier(0.16, 1, 0.3, 1)',
						fill: 'forwards'
					}
				);
			}
			animateIn();
			document.addEventListener('astro:page-load', animateIn);
		</script>

		<script>
			const syncFooterAccountLink = () => {
				const link = document.getElementById('footer-account-item') as HTMLAnchorElement | null;
				if (!link) return;
				const session = window.localStorage.getItem('aloha_session');
				if (session) {
					link.textContent = 'Mi Cuenta';
					link.setAttribute('href', '/dashboard');
					link.onclick = null;
				} else {
					link.textContent = 'Crear Cuenta';
					link.setAttribute('href', '#');
					link.onclick = (e) => { e.preventDefault(); window.dispatchEvent(new CustomEvent('aloha:open-auth')); };
				}
			};
			syncFooterAccountLink();
			window.addEventListener('aloha:auth-changed', syncFooterAccountLink);
			document.addEventListener('astro:page-load', syncFooterAccountLink);
		</script>

		<!-- Page transition loader -->
		<div
			id="page-loader"
			aria-hidden="true"
			style="position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:rgba(255,246,232,0.75);backdrop-filter:blur(4px);opacity:0;pointer-events:none;transition:opacity 0.18s ease;"
		>
			<span class="hibiscus-spin" style="font-size:2.5rem;user-select:none;">🌺</span>
		</div>
		<script>
			const pageLoader = document.getElementById('page-loader');
			document.addEventListener('astro:before-preparation', () => {
				if (pageLoader) pageLoader.style.opacity = '1';
			});
			document.addEventListener('astro:after-swap', () => {
				if (pageLoader) pageLoader.style.opacity = '0';
			});
		</script>
	</body>
</html>
