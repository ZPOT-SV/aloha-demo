---
import HeroOffersWidget from '../components/HeroOffersWidget';
import ProductCarousel from '../components/ProductCarousel';
import Layout from '../layouts/Layout.astro';

const tiers = [
  {
    emoji: '🌊',
    name: 'Rise',
    range: '0–49 Tikis',
    benefit: 'Acceso a beneficios de bienvenida y retos iniciales.',
    color: 'bg-brand',
    shadow: 'shadow-brand/30'
  },
  {
    emoji: '🤙🏻',
    name: 'Vibe',
    range: '50–149 Tikis',
    benefit: 'Bonos sorpresa y promociones especiales cada mes.',
    color: 'bg-highlight',
    shadow: 'shadow-highlight/30'
  },
  {
    emoji: '🌺',
    name: 'Aloha',
    range: '150+',
    benefit: 'Canjes premium y prioridad en nuevas experiencias.',
    color: 'bg-accent',
    shadow: 'shadow-accent/30'
  }
];
---

<Layout title="Aloha Loyalty" requiresAuth={false}>

  <!-- ░░ CAROUSEL — Productos más vendidos ░░ -->
  <section class="bg-[#FFF6E8] py-14">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid items-center gap-12 lg:grid-cols-[1fr_1.1fr]">
        <div data-animate class="space-y-4">
          <p class="text-xs font-bold uppercase tracking-[0.3em] text-brand">Menú destacado</p>
          <h2 class="font-heading text-4xl font-black leading-tight text-slate-950 md:text-5xl">
            Productos<br/>más vendidos
          </h2>
          <p class="max-w-sm leading-relaxed text-text-muted">
            Descubrí nuestras opciones más populares. Cada compra suma Tikis para tus premios.
          </p>
          <a href="/menu" class="inline-flex items-center gap-2 text-sm font-bold text-brand transition hover:text-deep-cta">
            Ver menú completo
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div data-animate>
          <ProductCarousel client:load />
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ HERO ░░ -->
  <section class="bg-[#FFF6E8] pb-10 pt-8 md:pt-12">
  <div class="mx-auto grid max-w-6xl items-center gap-8 px-6 lg:grid-cols-[1.1fr_0.9fr]">
    <div id="hero-logged-out-text" class="space-y-6">
      <div class="space-y-4">
        <h1 class="max-w-xl text-5xl font-black leading-[1.1] tracking-tight text-slate-950 md:text-6xl">
          Acumulá Tikis,<br/>
          <span class="bg-gradient-to-r from-brand to-accent bg-clip-text text-transparent">Viví la Experiencia</span>
        </h1>
        <p class="max-w-lg text-lg leading-relaxed text-text-muted md:text-xl">
          Por cada dólar que gastes, acumula un tiki que te sirve para desbloquear recompensas y subir de nivel para acceder a más beneficios
        </p>
      </div>

      <div class="flex flex-wrap gap-4">
        <button
          id="hero-open-auth"
          type="button"
          class="hidden rounded-full bg-brand px-8 py-3.5 text-base font-bold text-white shadow-xl shadow-brand/30 transition hover:brightness-90"
        >
          Empezá Ahora
        </button>
        <a
          href="/menu"
          class="rounded-full border-2 border-brand px-8 py-3.5 text-center text-base font-bold text-brand transition hover:bg-brand hover:text-white"
        >
          Ver Menú
        </a>
      </div>
    </div>

    <!-- Tiki mascot (logged out) -->
    <div id="hero-tiki" class="flex items-center justify-center">
      <img src="/tiki.png" alt="Tiki mascot" class="w-full max-w-sm drop-shadow-2xl" />
    </div>

    <!-- Balance widget (logged in only) — spans both columns -->
    <div id="hero-widget" class="hidden lg:col-span-2">
      <div class="mx-auto max-w-2xl">
        <HeroOffersWidget client:load />
      </div>
    </div>
  </div>
  </section>

  <!-- ░░ CÓMO FUNCIONA + NIVELES — merged ░░ -->
  <section class="bg-[#FFF6E8] py-16">
    <div class="mx-auto max-w-6xl px-6">
      <p data-animate class="text-center text-xs font-bold uppercase tracking-[0.3em] text-text-muted">Cómo funciona</p>
      <h2 data-animate class="mt-2 text-center font-heading text-3xl font-black text-slate-950 md:text-4xl">
        Tres pasos, infinitos beneficios
      </h2>
      <div class="mt-10 grid gap-0 md:grid-cols-3">
        <div data-animate class="group relative flex flex-col items-center px-8 py-6 text-center md:border-r md:border-dashed md:border-slate-200">
          <div class="grid h-14 w-14 place-items-center rounded-2xl bg-brand text-2xl text-white shadow-lg shadow-brand/30">🛒</div>
          <h3 class="mt-4 text-xl font-bold text-slate-900">Comprá</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-muted">Cada $1 que gastás en nuestras tiendas suma 1 Tiki automáticamente.</p>
        </div>
        <div data-animate class="group relative flex flex-col items-center px-8 py-6 text-center md:border-r md:border-dashed md:border-slate-200">
          <div class="grid h-14 w-14 place-items-center rounded-2xl bg-highlight text-2xl shadow-lg shadow-highlight/30">⚡</div>
          <h3 class="mt-4 text-xl font-bold text-slate-900">Completá Retos</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-muted">Misiones semanales que multiplicán tus puntos y te dan bonos extra.</p>
        </div>
        <div data-animate class="group relative flex flex-col items-center px-8 py-6 text-center">
          <div class="grid h-14 w-14 place-items-center rounded-2xl bg-cta text-2xl text-white shadow-lg shadow-cta/30">🎁</div>
          <h3 class="mt-4 text-xl font-bold text-slate-900">Canjeá</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-muted">Usá tus Tikis por bebidas gratis, descuentos y experiencias exclusivas.</p>
        </div>
      </div>

      <!-- Divider -->
      <div class="mt-14 border-t border-slate-200/70"></div>

      <!-- Subí de nivel -->
      <div class="mt-14">
        <p data-animate class="text-center text-xs font-bold uppercase tracking-[0.3em] text-text-muted">Subí de nivel</p>
        <h2 data-animate class="mt-2 text-center font-heading text-3xl font-black text-slate-950 md:text-4xl">
          Tres niveles, más beneficios
        </h2>
        <div class="mt-10 grid gap-0 md:grid-cols-3">
          {tiers.map((tier, i) => (
            <div
              data-animate
              class={`group relative flex flex-col items-center px-8 py-6 text-center ${
                i < tiers.length - 1 ? 'md:border-r md:border-dashed md:border-slate-200' : ''
              }`}
            >
              <div class="grid h-14 w-14 place-items-center rounded-2xl text-2xl">
                {tier.emoji}
              </div>
              <h3 class="mt-4 text-xl font-bold text-slate-900">{tier.name}</h3>
              <span class="mt-1 rounded-full bg-slate-100 px-3 py-0.5 text-xs font-bold text-slate-500">{tier.range}</span>
              <p class="mt-3 text-sm leading-relaxed text-text-muted">{tier.benefit}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <script>
    import { userSession } from '../stores';

    const syncHero = (): void => {
      const heroButton = document.getElementById('hero-open-auth');
      const heroTiki = document.getElementById('hero-tiki');
      const heroWidget = document.getElementById('hero-widget');
      const heroText = document.getElementById('hero-logged-out-text');
      const session = userSession.get();
      const loggedIn = session?.role === 'customer';

      heroButton?.classList.toggle('hidden', session !== null);
      heroTiki?.classList.toggle('hidden', loggedIn);
      heroWidget?.classList.toggle('hidden', !loggedIn);
      if (heroText) heroText.style.display = loggedIn ? 'none' : '';
    };

    const handleHeroAuthClick = (event: Event): void => {
      const target = event.target;
      if (!(target instanceof Element) || !target.closest('#hero-open-auth')) return;
      window.dispatchEvent(new CustomEvent('aloha:open-auth'));
    };

    userSession.subscribe(syncHero);
    document.addEventListener('click', handleHeroAuthClick);
    document.addEventListener('astro:page-load', syncHero);
    syncHero();
  </script>

  <script>
    let landingObserver: IntersectionObserver | null = null;

    const setupLandingAnimations = (): void => {
      const targets = Array.from(document.querySelectorAll<HTMLElement>('[data-animate]'));

      landingObserver?.disconnect();

      if (targets.length === 0) {
        return;
      }

      if (!('IntersectionObserver' in window)) {
        targets.forEach((target) => target.classList.add('visible'));
        return;
      }

      landingObserver = new IntersectionObserver(
        (entries, observer) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      targets.forEach((target) => landingObserver?.observe(target));
    };

    setupLandingAnimations();
    document.addEventListener('astro:page-load', setupLandingAnimations);
  </script>
</Layout>
