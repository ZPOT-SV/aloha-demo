---
import AuthModal from '../components/AuthModal';
import Layout from '../layouts/Layout.astro';

const tiers = [
  {
    emoji: '🌺',
    name: 'Rise',
    range: '0–49 Tikis',
    benefit: 'Acceso a beneficios de bienvenida y retos iniciales.'
  },
  {
    emoji: '🌊',
    name: 'Vibe',
    range: '50–149 Tikis',
    benefit: 'Bonos sorpresa y promociones especiales cada mes.'
  },
  {
    emoji: '🏄',
    name: 'Aloha',
    range: '150+',
    benefit: 'Canjes premium y prioridad en nuevas experiencias.'
  }
];
---

<Layout title="Aloha Loyalty" requiresAuth={false}>
  <section class="mx-auto flex max-w-6xl flex-col gap-16 px-6 pb-20 pt-14">
    <div class="grid items-center gap-10 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 rounded-full border border-highlight/50 bg-highlight/20 px-4 py-2 text-sm font-semibold text-slate-700">
          <span>🌴</span>
          <span>Programa de lealtad tropical para tus compras favoritas</span>
        </div>

        <div class="space-y-5">
          <h1 class="max-w-3xl text-5xl font-black tracking-tight text-slate-950 md:text-6xl">
            Acumulá Tikis, Viví la Experiencia
          </h1>
          <p class="max-w-2xl text-lg text-text-muted md:text-xl">
            Ganás 1 Tiki Point por cada $1 que comprás
          </p>
        </div>

        <div class="flex flex-col gap-4 sm:flex-row">
          <button
            id="hero-open-auth"
            type="button"
            class="hidden rounded-full bg-cta px-7 py-3.5 text-base font-bold text-white shadow-xl shadow-cta/30 transition hover:bg-deep-cta"
          >
            Empezá Ahora
          </button>
          <a
            href="/menu"
            class="rounded-full border-2 border-brand px-7 py-3.5 text-center text-base font-bold text-brand transition hover:bg-brand hover:text-white"
          >
            Ver Menú
          </a>
        </div>
      </div>

      <div class="grid gap-4 rounded-[2rem] border border-brand/10 bg-white/80 p-6 shadow-2xl shadow-brand/10 backdrop-blur-sm">
        <div class="rounded-[1.5rem] bg-brand p-6 text-white">
          <p
            id="hero-balance-label"
            class="text-sm font-semibold uppercase tracking-[0.28em] text-white/80"
          >
            Saldo de ejemplo
          </p>
          <p id="hero-balance-value" class="mt-4 text-5xl font-black">142</p>
          <p class="mt-2 text-lg font-semibold">Tikis listos para canjear</p>
        </div>
        <div class="grid gap-4 md:grid-cols-3 lg:grid-cols-1">
          <div class="rounded-[1.5rem] bg-surface p-5">
            <p class="text-sm font-semibold text-text-muted">Nivel actual</p>
            <p class="mt-2 text-2xl font-black text-brand">🌊 Vibe</p>
          </div>
          <div class="rounded-[1.5rem] bg-surface p-5">
            <p class="text-sm font-semibold text-text-muted">Premio cercano</p>
            <p class="mt-2 text-2xl font-black text-slate-900">🎁 Bebida Gratis</p>
          </div>
          <div class="rounded-[1.5rem] bg-surface p-5">
            <p class="text-sm font-semibold text-text-muted">Reto activo</p>
            <p class="mt-2 text-2xl font-black text-slate-900">⚡ Comprador Frecuente</p>
          </div>
        </div>
      </div>
    </div>

    <section class="grid gap-5 md:grid-cols-3">
      <article class="rounded-[1.75rem] border border-brand/10 bg-white/75 p-6 shadow-lg shadow-brand/5">
        <p class="text-3xl">🌺</p>
        <h2 class="mt-4 text-2xl font-black text-slate-950">Acumulá Tikis</h2>
        <p class="mt-3 text-text-muted">Convertí cada compra en puntos que te acercan a más recompensas.</p>
      </article>
      <article class="rounded-[1.75rem] border border-brand/10 bg-white/75 p-6 shadow-lg shadow-brand/5">
        <p class="text-3xl">🎁</p>
        <h2 class="mt-4 text-2xl font-black text-slate-950">Canjeá Premios</h2>
        <p class="mt-3 text-text-muted">Usá tus tikis para bebidas, descuentos y experiencias exclusivas.</p>
      </article>
      <article class="rounded-[1.75rem] border border-brand/10 bg-white/75 p-6 shadow-lg shadow-brand/5">
        <p class="text-3xl">⚡</p>
        <h2 class="mt-4 text-2xl font-black text-slate-950">Completá Retos</h2>
        <p class="mt-3 text-text-muted">Desbloqueá bonos extra con misiones semanales y metas especiales.</p>
      </article>
    </section>

    <section class="space-y-6">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-text-muted">Niveles Aloha</p>
        <h2 class="text-3xl font-black text-slate-950 md:text-4xl">Subí de nivel y mejorá tus beneficios</h2>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {tiers.map((tier) => (
          <article class="rounded-[1.75rem] border border-brand/10 bg-white p-6 shadow-xl shadow-brand/5">
            <div class="flex items-center justify-between">
              <span class="text-4xl">{tier.emoji}</span>
              <span class="rounded-full bg-brand/8 px-3 py-1 text-sm font-bold text-brand">{tier.range}</span>
            </div>
            <h3 class="mt-5 text-2xl font-black text-slate-950">{tier.name}</h3>
            <p class="mt-3 text-text-muted">{tier.benefit}</p>
          </article>
        ))}
      </div>
    </section>
  </section>

  <AuthModal client:load />

  <script>
    import { tikiBalance, userSession } from '../stores';

    const heroButton = document.getElementById('hero-open-auth');
    const heroBalanceLabel = document.getElementById('hero-balance-label');
    const heroBalanceValue = document.getElementById('hero-balance-value');
    const exampleBalanceLabel = 'Saldo de ejemplo';
    const liveBalanceLabel = 'Saldo';
    const exampleBalanceValue = '142';

    const syncHeroButtonVisibility = (): void => {
      const session = userSession.get();
      heroButton?.classList.toggle('hidden', session !== null);
    };

    const syncHeroBalance = (): void => {
      const session = userSession.get();
      const showLiveBalance = session?.role === 'customer';

      if (heroBalanceLabel) {
        heroBalanceLabel.textContent = showLiveBalance ? liveBalanceLabel : exampleBalanceLabel;
      }

      if (heroBalanceValue) {
        heroBalanceValue.textContent = showLiveBalance
          ? String(tikiBalance.get())
          : exampleBalanceValue;
      }
    };

    userSession.subscribe(() => {
      syncHeroButtonVisibility();
      syncHeroBalance();
    });

    tikiBalance.subscribe(() => {
      syncHeroBalance();
    });

    syncHeroButtonVisibility();
    syncHeroBalance();

    heroButton?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('aloha:open-auth'));
    });
  </script>
</Layout>
