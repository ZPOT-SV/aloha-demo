---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Retos | Aloha Loyalty" requiresAuth={true} customerOnly={true}>
  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="rounded-[2rem] border border-brand/10 bg-white/85 p-8 shadow-2xl shadow-brand/10 backdrop-blur-sm">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-text-muted">Retos</p>
      <h1 class="mt-3 text-4xl font-black text-slate-950">Tus próximas metas se verán aquí</h1>
      <p class="mt-4 max-w-2xl text-lg text-text-muted">
        Dejé esta ruta preparada para conectar los retos y bonificaciones del programa sin romper la navegación actual.
      </p>
    </div>
  </section>
</Layout>
