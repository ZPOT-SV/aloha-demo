---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gift Cards | Aloha Loyalty" requiresAuth={true} customerOnly={true}>
  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="rounded-[2rem] border border-brand/10 bg-white/85 p-8 shadow-2xl shadow-brand/10 backdrop-blur-sm">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-text-muted">Gift Cards</p>
      <h1 class="mt-3 text-4xl font-black text-slate-950">Tus tarjetas de regalo aparecerán aquí</h1>
      <p class="mt-4 max-w-2xl text-lg text-text-muted">
        Dejé esta ruta lista para que el dashboard apunte a una pantalla válida mientras completamos la siguiente etapa.
      </p>
    </div>
  </section>
</Layout>
