import { useEffect, useMemo, useState } from 'react';

import { QRCodeSVG } from 'qrcode.react';
import { useStore } from '@nanostores/react';

import {
  challenges,
  selectedStore,
  setChallenges,
  setTikiBalance,
  setTransactionHistory,
  setUserSession,
  tikiBalance,
  transactionHistory,
  userSession
} from '../stores';
import type { Challenge, MenuItem, Transaction, User } from '../types';
import WhatsAppPanel from './WhatsAppPanel';

type PurchaseState = 'idle' | 'confirming' | 'qr' | 'whatsapp';

interface CompletedPurchase {
  item: MenuItem;
  transaction: Transaction;
  storeName: string;
  storePhone: string;
  newBalance: number;
}

function getTierLabel(balance: number): string {
  if (balance >= 150) {
    return 'Aloha';
  }

  if (balance >= 50) {
    return 'Vibe';
  }

  return 'Rise';
}

function getTierId(balance: number): User['tierId'] {
  if (balance >= 150) {
    return 'aloha';
  }

  if (balance >= 50) {
    return 'vibe';
  }

  return 'rise';
}

function updateChallengeProgress(
  currentChallenges: Challenge[],
  itemCategory: MenuItem['category'],
  timestamp: Date
): Challenge[] {
  return currentChallenges.map((challenge) => {
    if (challenge.isLocked || challenge.isCompleted) {
      return challenge;
    }

    let increment = 0;

    if (challenge.name === 'Comprador Frecuente') {
      increment = 1;
    } else if (challenge.name === 'Fan de los Bowls' && itemCategory === 'bowls') {
      increment = 1;
    } else if (challenge.name === 'Madrugador' && timestamp.getHours() < 10) {
      increment = 1;
    }

    if (increment === 0) {
      return challenge;
    }

    const currentCount = Math.min(challenge.currentCount + increment, challenge.targetCount);

    return {
      ...challenge,
      currentCount,
      isCompleted: currentCount >= challenge.targetCount
    };
  });
}

export default function PurchaseFlow() {
  const activeStore = useStore(selectedStore);
  const currentUser = useStore(userSession);
  const balance = useStore(tikiBalance);
  const challengeList = useStore(challenges);
  const history = useStore(transactionHistory);

  const [purchaseState, setPurchaseState] = useState<PurchaseState>('idle');
  const [pendingItem, setPendingItem] = useState<MenuItem | null>(null);
  const [completedPurchase, setCompletedPurchase] = useState<CompletedPurchase | null>(null);
  const [tierToast, setTierToast] = useState<string | null>(null);

  useEffect(() => {
    const onPurchaseRequest = (event: Event) => {
      const { detail } = event as CustomEvent<MenuItem>;

      if (!detail || !activeStore) {
        return;
      }

      setPendingItem(detail);
      setPurchaseState('confirming');
    };

    window.addEventListener('aloha:purchase-request', onPurchaseRequest);

    return () => {
      window.removeEventListener('aloha:purchase-request', onPurchaseRequest);
    };
  }, [activeStore]);

  useEffect(() => {
    if (!tierToast) {
      return;
    }

    const timeoutId = window.setTimeout(() => {
      setTierToast(null);
    }, 4000);

    return () => {
      window.clearTimeout(timeoutId);
    };
  }, [tierToast]);

  const projectedBalance = useMemo(() => {
    return pendingItem ? balance + pendingItem.tikiEarn : balance;
  }, [balance, pendingItem]);

  const closeFlow = () => {
    setPurchaseState('idle');
    setPendingItem(null);
    setCompletedPurchase(null);
  };

  const confirmPurchase = () => {
    if (!pendingItem || !activeStore || !currentUser) {
      closeFlow();
      return;
    }

    const timestamp = new Date();
    const transactionId = `TXN-${Date.now()}`;
    const newBalance = balance + pendingItem.tikiEarn;
    const qrPayload = JSON.stringify({
      userId: currentUser.id,
      transactionId,
      tikiEarned: pendingItem.tikiEarn,
      timestamp: timestamp.toISOString()
    });

    const transaction: Transaction = {
      id: transactionId,
      userId: currentUser.id,
      storeId: activeStore.id,
      items: [pendingItem],
      tikiEarned: pendingItem.tikiEarn,
      qrPayload,
      timestamp: timestamp.toISOString()
    };

    const nextHistory = [transaction, ...history];
    const nextChallenges = updateChallengeProgress(challengeList, pendingItem.category, timestamp);
    const previousTier = getTierLabel(balance);
    const nextTier = getTierLabel(newBalance);
    const nextSession: User = {
      ...currentUser,
      tikiBalance: newBalance,
      tierId: getTierId(newBalance)
    };

    setTikiBalance(newBalance);
    setTransactionHistory(nextHistory);
    setChallenges(nextChallenges);
    setUserSession(nextSession);
    window.dispatchEvent(new CustomEvent('aloha:auth-changed'));

    if (previousTier !== nextTier) {
      setTierToast(
        newBalance >= 150
          ? '🏄 ¡Alcanzaste Aloha! El nivel más alto. ¡Eres increíble!'
          : '🌊 ¡Subiste a Vibe! Seguí acumulando Tikis.'
      );
    }

    setCompletedPurchase({
      item: pendingItem,
      transaction,
      storeName: activeStore.name,
      storePhone: activeStore.phone,
      newBalance
    });
    setPurchaseState('qr');
  };

  return (
    <>
      {purchaseState === 'confirming' && pendingItem && activeStore ? (
        <div className="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/55 px-4 backdrop-blur-sm">
          <div className="w-full max-w-lg rounded-[2rem] border border-brand/10 bg-white p-6 shadow-2xl shadow-brand/20">
            <p className="text-sm font-semibold uppercase tracking-[0.24em] text-text-muted">Confirmar compra</p>

            <div className="mt-5 flex items-start gap-4 rounded-[1.5rem] bg-surface p-4">
              <div className="grid h-24 w-24 place-items-center rounded-[1.25rem] bg-linear-to-br from-brand to-cta text-4xl text-white">
                {pendingItem.category === 'bebidas'
                  ? '🥤'
                  : pendingItem.category === 'bowls'
                    ? '🥣'
                    : '☀️'}
              </div>
              <div className="flex-1">
                <h3 className="text-2xl font-black text-slate-950">{pendingItem.name}</h3>
                <p className="mt-2 text-sm text-text-muted">{activeStore.name}</p>
                <p className="mt-3 text-lg font-black text-slate-950">${pendingItem.priceUSD.toFixed(2)} USD</p>
              </div>
            </div>

            <div className="mt-5 grid gap-3 sm:grid-cols-2">
              <div className="rounded-[1.25rem] bg-highlight px-4 py-3">
                <p className="text-xs font-semibold uppercase tracking-[0.14em] text-slate-700">Ganancia</p>
                <p className="mt-2 text-xl font-black text-slate-950">+{pendingItem.tikiEarn} Tiki Points</p>
              </div>
              <div className="rounded-[1.25rem] bg-brand/8 px-4 py-3">
                <p className="text-xs font-semibold uppercase tracking-[0.14em] text-slate-700">Nuevo saldo</p>
                <p className="mt-2 text-xl font-black text-slate-950">{projectedBalance} Tikis</p>
              </div>
            </div>

            <div className="mt-6 flex flex-wrap items-center justify-end gap-4">
              <button
                className="text-sm font-bold text-brand transition hover:text-deep-cta"
                onClick={closeFlow}
                type="button"
              >
                Cancelar
              </button>
              <button
                className="rounded-full bg-cta px-5 py-3 text-sm font-bold text-white shadow-lg shadow-cta/20 transition hover:bg-deep-cta"
                onClick={confirmPurchase}
                type="button"
              >
                Confirmar Compra
              </button>
            </div>
          </div>
        </div>
      ) : null}

      {purchaseState === 'qr' && completedPurchase ? (
        <div className="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/55 px-4 backdrop-blur-sm">
          <div className="w-full max-w-lg rounded-[2rem] border border-brand/10 bg-white p-6 text-center shadow-2xl shadow-brand/20">
            <div className="mx-auto grid h-16 w-16 place-items-center rounded-full bg-accent/20 text-4xl text-brand">
              ✓
            </div>
            <h3 className="mt-5 text-3xl font-black text-slate-950">¡Compra Registrada!</h3>
            <p className="mt-3 text-3xl font-black text-highlight">
              +{completedPurchase.item.tikiEarn} Tiki Points
            </p>

            <div className="mt-6 flex justify-center">
              <div className="rounded-[1.5rem] bg-white p-4 shadow-lg">
                <QRCodeSVG size={200} value={completedPurchase.transaction.qrPayload} />
              </div>
            </div>

            <p className="mt-5 text-sm text-text-muted">
              Mostrá este código en tienda para validar tus Tiki Points.
            </p>
            <p className="mt-3 text-xs font-medium text-text-muted">
              Transacción ID: {completedPurchase.transaction.id}
            </p>

            <button
              className="mt-6 rounded-full border border-brand px-5 py-3 text-sm font-bold text-brand transition hover:bg-brand hover:text-white"
              onClick={() => setPurchaseState('whatsapp')}
              type="button"
            >
              Cerrar
            </button>
          </div>
        </div>
      ) : null}

      {purchaseState === 'whatsapp' && completedPurchase ? (
        <WhatsAppPanel
          onDismiss={closeFlow}
          customerName={currentUser?.name ?? ''}
          storeName={completedPurchase.storeName}
          storePhone={completedPurchase.storePhone}
          tikiEarned={completedPurchase.item.tikiEarn}
          transactionId={completedPurchase.transaction.id}
        />
      ) : null}

      {tierToast ? (
        <div className="fixed bottom-5 right-5 z-50 max-w-sm rounded-[1.5rem] border border-highlight bg-slate-950 px-5 py-4 text-sm font-semibold text-white shadow-2xl shadow-slate-950/30">
          {tierToast}
        </div>
      ) : null}
    </>
  );
}
