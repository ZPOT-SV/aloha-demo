<header class="sticky top-0 z-40 border-b border-brand/10 bg-white/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
    <a href="/" class="flex items-center gap-3 text-brand">
      <img
        src="/logo.png"
        alt="Aloha Loyalty"
        class="h-12 w-auto object-contain"
      />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.32em] text-text-muted">Aloha Loyalty</p>
        <p class="text-lg font-black">El sabor que premia</p>
      </div>
    </a>

    <nav class="hidden items-center gap-6 text-sm font-semibold text-slate-700 md:flex">
      <a class="transition hover:text-brand" href="/">Inicio</a>
      <a class="transition hover:text-brand" href="/menu">Menú</a>
      <a class="transition hover:text-brand" href="/tiendas">Tiendas</a>
      <a class="transition hover:text-brand" href="/retos">Retos</a>
    </nav>

    <div class="flex items-center gap-3">
      <button
        id="cart-button"
        type="button"
        class="relative rounded-full border border-brand/15 bg-white px-4 py-2 text-lg text-brand shadow-sm transition hover:bg-brand/5"
      >
        🛒
        <span
          id="cart-count"
          class="absolute -right-2 -top-2 hidden min-w-5 rounded-full bg-red-500 px-1.5 py-0.5 text-xs font-bold text-white"
        >
          0
        </span>
      </button>
      <button
        id="login-button"
        type="button"
        class="rounded-full bg-cta px-5 py-2.5 text-sm font-bold text-white shadow-lg shadow-cta/20 transition hover:bg-deep-cta"
      >
        Iniciar Sesión
      </button>

      <div id="user-actions" class="hidden items-center gap-3">
        <div class="rounded-full bg-highlight px-4 py-2 text-sm font-bold text-slate-900 shadow-md shadow-highlight/30">
          <span id="user-tikis">0</span>
          <span>Tikis</span>
        </div>
        <a href="/dashboard" class="flex items-center gap-2 cursor-pointer hover:opacity-80 transition-opacity rounded-full border border-brand/15 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm">
          <span id="user-tier-emoji">🌺</span>
          <span id="user-name">Invitado</span>
        </a>
        <button
          id="logout-button"
          type="button"
          class="text-sm font-semibold text-brand underline-offset-4 transition hover:underline"
        >
          Salir
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  import { cart, setCartOpen } from '../stores';
  import type { CartItem } from '../types';

  const cartButton = document.getElementById('cart-button');
  const cartCount = document.getElementById('cart-count');
  const sessionKey = 'aloha_session';

  const syncCartCount = (items: readonly CartItem[]) => {
    const hasSession = Boolean(window.localStorage.getItem(sessionKey));
    const total = items.reduce((sum, entry) => sum + entry.quantity, 0);

    if (!cartCount) {
      return;
    }

    cartCount.textContent = String(total);
    cartCount.classList.toggle('hidden', total === 0 || !hasSession);
  };

  cart.subscribe((items) => {
    syncCartCount(items);
  });
  syncCartCount(cart.get());

  cartButton?.addEventListener('click', () => {
    if (!window.localStorage.getItem(sessionKey)) {
      window.location.href = '/?auth=required';
      return;
    }

    setCartOpen(true);
  });
</script>

<script>
  import { logoutUser } from '../stores';
  import type { User } from '../types';

  const sessionKey = 'aloha_session';
  const tikiKey = 'aloha_tikis';

  const cartCount = document.getElementById('cart-count');
  const loginButton = document.getElementById('login-button');
  const userActions = document.getElementById('user-actions');
  const userTikis = document.getElementById('user-tikis');
  const userTierEmoji = document.getElementById('user-tier-emoji');
  const userName = document.getElementById('user-name');
  const logoutButton = document.getElementById('logout-button');

  const tierEmojiMap: Record<string, string> = {
    rise: '🌺 Rise',
    vibe: '🌊 Vibe',
    aloha: '🏄 Aloha'
  };

  const getTierEmoji = (tierId: User['tierId']): string => {
    if (!tierId) {
      return '👑';
    }

    return tierEmojiMap[tierId.toLowerCase()] ?? '🌺';
  };

  const syncNavbar = () => {
    const rawSession = window.localStorage.getItem(sessionKey);

    if (!rawSession) {
      loginButton?.classList.remove('hidden');
      userActions?.classList.add('hidden');
      cartCount?.classList.add('hidden');
      return;
    }

    try {
      const session = JSON.parse(rawSession) as User;
      const storedTikis = Number(window.localStorage.getItem(tikiKey) ?? session.tikiBalance ?? 0);

      if (userTikis) {
        userTikis.textContent = String(storedTikis);
      }

      if (userTierEmoji) {
        userTierEmoji.textContent = getTierEmoji(session.tierId);
      }

      if (userName) {
        userName.textContent = session.username;
      }

      loginButton?.classList.add('hidden');
      userActions?.classList.remove('hidden');
      userActions?.classList.add('flex');
    } catch {
      logoutUser();
      loginButton?.classList.remove('hidden');
      userActions?.classList.add('hidden');
      cartCount?.classList.add('hidden');
    }
  };

  loginButton?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('aloha:open-auth'));
  });

  logoutButton?.addEventListener('click', () => {
    logoutUser();
    window.location.href = '/';
  });

  window.addEventListener('storage', syncNavbar);
  window.addEventListener('aloha:auth-changed', syncNavbar);
  syncNavbar();
</script>
